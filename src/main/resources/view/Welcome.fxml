<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: #F4F7F6; -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.WelcomeController">
    <children>
        <VBox alignment="CENTER" maxWidth="480.0" minWidth="400.0" prefWidth="440.0" spacing="30.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 25, 0, 0, 5);">
            <padding>
                <Insets bottom="50.0" left="40.0" right="40.0" top="50.0" />
            </padding>
            <children>
                <VBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Label text="📚" textFill="#1a365d">
                            <font><Font size="60.0" /></font>
                        </Label>
                        <Label text="FlashcardAH" textFill="#1A365D">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>
                        <Label text="Hành trình làm chủ từ vựng của bạn" textFill="#718096">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox spacing="15.0">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                    <children>
                        <Button maxWidth="Infinity" onAction="#openLogin" prefHeight="50.0" style="-fx-background-color: #7B61FF; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;" text="Đăng nhập">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Button>
                        <Button maxWidth="Infinity" onAction="#openRegister" prefHeight="50.0" style="-fx-background-color: #f8fafc; -fx-text-fill: #4A90E2; -fx-border-color: #4A90E2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-width: 1.5; -fx-cursor: hand;" text="Đăng ký tài khoản mới">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>