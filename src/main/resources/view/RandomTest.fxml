<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="720.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #f0f4ff, #d9e2ff); -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.RandomTestController">
    <children>
        <VBox alignment="CENTER" maxWidth="1000.0" prefWidth="550.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 20, 0, 0, 5);" StackPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER" style="-fx-background-color: #F7FAFC; -fx-background-radius: 10; -fx-padding: 15 20; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
                    <children>
                        <Label text="KIỂM TRA NĂNG LỰC" textFill="#1A365D" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <StackPane HBox.hgrow="ALWAYS" />
                        <Label fx:id="scoreLabel" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 15; -fx-font-weight: bold;" text="Điểm: 0/0" />
                    </children>
                </HBox>

                <VBox alignment="CENTER" spacing="8.0">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="progressLabel" style="-fx-text-fill: #718096; -fx-font-weight: bold;" text="Câu 1/10" />
                        </HBox>
                        <ProgressBar fx:id="progressBar" prefHeight="8.0" prefWidth="520.0" progress="0.1" style="-fx-accent: #48BB78; -fx-control-inner-background: #E2E8F0;" />
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label fx:id="questionTypeLabel" style="-fx-text-fill: #A0AEC0; -fx-font-weight: bold; -fx-letter-spacing: 1;" text="NGHĨA CỦA TỪ SAU LÀ GÌ?" />

                        <Label fx:id="questionLabel" alignment="CENTER" style="-fx-text-fill: #2D3748;" text="Loading..." textAlignment="CENTER" wrapText="true">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>

                        <TextField fx:id="answerField" alignment="CENTER" onAction="#submitAnswer" prefHeight="50.0" promptText="Nhập câu trả lời..." style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E0; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <font> <Font size="16.0" /> </font>
                        </TextField>

                        <VBox fx:id="multipleChoicePane" alignment="CENTER" spacing="12.0" visible="false">
                            <children>
                                <Button fx:id="optionButton1" mnemonicParsing="false" onAction="#selectOption1" prefHeight="50.0" prefWidth="520.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 20;" text="Option 1">
                                    <font> <Font size="15.0" /> </font>
                                </Button>
                                <Button fx:id="optionButton2" mnemonicParsing="false" onAction="#selectOption2" prefHeight="50.0" prefWidth="520.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 20;" text="Option 2">
                                    <font> <Font size="15.0" /> </font>
                                </Button>
                                <Button fx:id="optionButton3" mnemonicParsing="false" onAction="#selectOption3" prefHeight="50.0" prefWidth="520.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 20;" text="Option 3">
                                    <font> <Font size="15.0" /> </font>
                                </Button>
                            </children>
                        </VBox>

                        <VBox fx:id="wordScramblePane" alignment="CENTER" spacing="15.0" visible="false">
                            <children>
                                <Label style="-fx-text-fill: #A0AEC0; -fx-font-weight: bold;" text="SẮP XẾP LẠI CÁC CHỮ CÁI:" />
                                <Label fx:id="scrambledLabel" alignment="CENTER" style="-fx-text-fill: #D69E2E; -fx-letter-spacing: 4px;" text="SCRAMBLED">
                                    <font> <Font name="System Bold" size="24.0" /> </font>
                                </Label>
                                <TextField fx:id="unscrambleField" alignment="CENTER" onAction="#submitAnswer" prefHeight="50.0" promptText="Nhập từ đúng..." style="-fx-background-color: #F8FAFC; -fx-border-color: #D69E2E; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-background-radius: 8;">
                                    <font> <Font size="16.0" /> </font>
                                </TextField>
                            </children>
                        </VBox>

                        <Label fx:id="feedbackLabel" style="-fx-font-weight: bold;" text="" textFill="#48BB78" visible="false">
                            <font> <Font size="14.0" /> </font>
                        </Label>

                        <StackPane>
                            <children>
                                <Button fx:id="submitButton" defaultButton="true" mnemonicParsing="false" onAction="#submitAnswer" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Xác nhận">
                                    <font> <Font name="System Bold" size="15.0" /> </font>
                                </Button>
                                <Button fx:id="nextButton" mnemonicParsing="false" onAction="#nextQuestion" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #7B61FF; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Câu tiếp theo →" visible="false">
                                    <font> <Font name="System Bold" size="15.0" /> </font>
                                </Button>
                            </children>
                        </StackPane>
                    </children>
                </VBox>
            </children>
        </VBox>
        <Button mnemonicParsing="false" onAction="#backToTestMenu" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="← Quay lại" textFill="#4a5568" StackPane.alignment="TOP_LEFT">
            <font><Font name="System Bold" size="14.0" /></font>
            <StackPane.margin>
                <Insets left="20.0" top="20.0" />
            </StackPane.margin>
        </Button>
    </children>
</StackPane>