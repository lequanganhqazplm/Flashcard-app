<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: rgba(244, 247, 246, 0.8); -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.AddTopicController">
   <children>
      <VBox alignment="CENTER" maxWidth="450.0" prefHeight="250.0" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 20, 0, 0, 5);" StackPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Label text="Tạo Chủ Đề Mới" textFill="#1A365D">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>

            <TextField fx:id="topicNameField" prefHeight="45.0" promptText="Nhập tên chủ đề (VD: Trái cây, Toeic 600...)" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;">
               <font>
                  <Font size="14.0" />
               </font>
            </TextField>

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-background-radius: 8; -fx-cursor: hand;" text="Hủy bỏ">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
                  <Button fx:id="continueButton" mnemonicParsing="false" onAction="#addTopicName" prefHeight="42.0" prefWidth="150.0" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Tạo chủ đề">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>