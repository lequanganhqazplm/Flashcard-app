<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="772.0" prefWidth="760.0" style="-fx-background-color: linear-gradient(to bottom right, #f0f4ff, #d9e2ff); -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.ReviewCardController">
    <children>
        <VBox alignment="CENTER" maxWidth="650.0" spacing="20.0" style="-fx-background-color: transparent;" StackPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <StackPane HBox.hgrow="ALWAYS">
                            <Label fx:id="topicNameLabel" text="Đang tải chủ đề..." textFill="#1A365D">
                                <font>
                                    <Font name="System Bold" size="24.0" />
                                </font>
                            </Label>
                        </StackPane>
                    </children>
                </HBox>

                <StackPane prefHeight="400.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox fx:id="backCardSide" alignment="CENTER" spacing="10.0" style="-fx-background-color: #F7FAFC; -fx-background-radius: 20; -fx-border-color: #4A90E2; -fx-border-width: 2; -fx-border-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 8);" visible="false">
                            <children>
                                <Label fx:id="definitionLabel" text="..." textAlignment="CENTER" textFill="#2B6CB0" wrapText="true">
                                    <font> <Font name="System Bold" size="40.0" /> </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox fx:id="frontCardSide" alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 8);">
                            <children>
                                <Label fx:id="vocabLabel" text="..." textAlignment="CENTER" textFill="#2D3748" wrapText="true">
                                    <font> <Font name="System Bold" size="50.0" /> </font>
                                </Label>
                                <Label text="Bấm lật thẻ để xem nghĩa" textFill="#A0AEC0">
                                    <font> <Font size="14.0" /> </font>
                                    <VBox.margin><Insets top="20.0"/></VBox.margin>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <Button fx:id="flipButton" mnemonicParsing="false" onAction="#handleFlip" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #7B61FF; -fx-text-fill: white; -fx-background-radius: 25; -fx-cursor: hand;" text="🔄 Lật thẻ">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                    <VBox.margin><Insets bottom="10.0" top="10.0"/></VBox.margin>
                </Button>

                <HBox alignment="CENTER" spacing="40.0">
                    <children>
                        <Button fx:id="prevButton" mnemonicParsing="false" onAction="#handlePrevious" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="← Từ trước" textFill="#4A5568">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>

                        <Button fx:id="learnedButton" mnemonicParsing="false" onAction="#handleMarkLearned" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #48BB78; -fx-background-radius: 8; -fx-cursor: hand;" text="✓ Đã thuộc" textFill="WHITE">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>

                        <Button fx:id="nextButton" mnemonicParsing="false" onAction="#handleNext" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Từ sau →" textFill="#4A5568">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="← Quay lại" textFill="#4a5568" StackPane.alignment="TOP_LEFT">
         <font><Font name="System Bold" size="14.0" /></font>
         <StackPane.margin>
            <Insets left="20.0" top="20.0" />
         </StackPane.margin>
      </Button>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</StackPane>