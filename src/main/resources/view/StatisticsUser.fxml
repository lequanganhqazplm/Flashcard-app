<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane style="-fx-background-color: transparent; -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.StatisticsUserController">

   <AnchorPane prefHeight="50.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <children>
         <Button fx:id="btnBack" layoutX="15.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="← Trở về Dashboard" textFill="#4a5568">
            <font><Font name="System Bold" size="14.0" /></font>
         </Button>
      </children>
   </AnchorPane>

   <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="60.0">
      <content>
         <HBox alignment="TOP_CENTER" style="-fx-background-color: transparent;">
            <padding><Insets bottom="30.0" left="0.0" right="0.0" top="10.0" /></padding>
            <children>
               <VBox maxWidth="550.0" prefWidth="550.0" spacing="20.0">
                  <children>

                     <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                           <HBox alignment="CENTER_LEFT" spacing="6.0">
                              <children>
                                 <Label style="-fx-text-fill: #1A365D;" text="Thống Kê Tổng Quan">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                 </Label>
                              </children>
                              <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                           </HBox>

                           <HBox spacing="15.0">
                              <VBox style="-fx-background-color: #F7FAFC; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                 <Label text="Tổng từ vựng" textFill="#718096" />
                                 <Label fx:id="lblTotalWords" text="0" textFill="#4A90E2"><font><Font name="System Bold" size="28.0" /></font></Label>
                              </VBox>
                              <VBox style="-fx-background-color: #F0FFF4; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                 <Label text="Từ đã học" textFill="#718096" />
                                 <Label fx:id="lblLearnedWords" text="0" textFill="#48BB78"><font><Font name="System Bold" size="28.0" /></font></Label>
                              </VBox>
                           </HBox>
                           <HBox spacing="15.0">
                              <VBox style="-fx-background-color: #FFF5F5; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                 <Label text="Chủ đề tham gia" textFill="#718096" />
                                 <Label fx:id="lblTotalTopics" text="0" textFill="#E53E3E"><font><Font name="System Bold" size="28.0" /></font></Label>
                              </VBox>
                              <VBox style="-fx-background-color: #FAF5FF; -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                 <Label text="Điểm trung bình" textFill="#718096" />
                                 <Label fx:id="lblAvgScore" text="--" textFill="#805AD5"><font><Font name="System Bold" size="28.0" /></font></Label>
                              </VBox>
                           </HBox>
                        </children>
                     </VBox>

                     <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                           <Label style="-fx-text-fill: #1A365D;" text="Lịch Sử Bài Kiểm Tra">
                              <font><Font name="System Bold" size="18.0" /></font>
                              <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                           </Label>
                           <HBox style="-fx-background-color: #EDF2F7; -fx-background-radius: 6; -fx-padding: 10;">
                              <children>
                                 <Label prefWidth="200.0" style="-fx-text-fill: #4A5568;" text="Loại bài"><font><Font name="System Bold" size="13.0" /></font></Label>
                                 <Label prefWidth="100.0" style="-fx-text-fill: #4A5568;" text="Điểm"><font><Font name="System Bold" size="13.0" /></font></Label>
                                 <Label prefWidth="80.0" style="-fx-text-fill: #4A5568;" text="Tỉ lệ"><font><Font name="System Bold" size="13.0" /></font></Label>
                                 <Label style="-fx-text-fill: #4A5568;" text="Thời gian"><font><Font name="System Bold" size="13.0" /></font></Label>
                              </children>
                           </HBox>
                           <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="200.0" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED">
                              <content>
                                 <VBox fx:id="testResultsContainer" spacing="5.0">
                                    <Label fx:id="lblNoResults" style="-fx-text-fill: #A0AEC0;" text="Chưa có bài kiểm tra nào." />
                                 </VBox>
                              </content>
                           </ScrollPane>
                        </children>
                     </VBox>

                     <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 3);">
                        <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        <children>
                           <Label style="-fx-text-fill: #1A365D;" text="Chuỗi Học Tập (Streak)">
                              <font><Font name="System Bold" size="18.0" /></font>
                              <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                           </Label>
                           <HBox spacing="15.0">
                              <VBox alignment="CENTER" style="-fx-background-color: linear-gradient(to right, #ED8936, #DD6B20); -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                                 <Label text="🔥" textFill="WHITE"><font><Font size="24.0" /></font></Label>
                                 <Label fx:id="lblCurrentStreak" text="0" textFill="WHITE"><font><Font name="System Bold" size="36.0" /></font></Label>
                                 <Label text="Streak hiện tại" textFill="WHITE" />
                              </VBox>
                              <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                 <VBox alignment="CENTER" style="-fx-background-color: #FFF5F5; -fx-background-radius: 10; -fx-padding: 10;" VBox.vgrow="ALWAYS">
                                    <Label fx:id="lblLongestStreak" text="0" textFill="#C53030"><font><Font name="System Bold" size="20.0" /></font></Label>
                                    <Label text="Kỷ lục Streak" textFill="#E53E3E" />
                                 </VBox>
                                 <VBox alignment="CENTER" style="-fx-background-color: #EBF8FF; -fx-background-radius: 10; -fx-padding: 10;" VBox.vgrow="ALWAYS">
                                    <Label fx:id="lblFreezeCount" text="0" textFill="#2B6CB0"><font><Font name="System Bold" size="20.0" /></font></Label>
                                    <Label text="Bảo vệ Streak" textFill="#3182CE" />
                                 </VBox>
                              </VBox>
                           </HBox>
                        </children>
                     </VBox>

                  </children>
               </VBox>
            </children>
         </HBox>
      </content>
   </ScrollPane>
</AnchorPane>