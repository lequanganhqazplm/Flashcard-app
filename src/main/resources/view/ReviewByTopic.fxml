<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="738.0" prefWidth="760.0" style="-fx-background-color: linear-gradient(to bottom right, #f0f4ff, #d9e2ff); -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.ReviewTopicController">
   <children>
      <VBox alignment="CENTER" maxWidth="900.0" minWidth="400.0" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 4);" StackPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         <children>
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <TextField fx:id="searchField" prefHeight="42.0" promptText="🔍 Tìm tên chủ đề ôn tập..." style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;" HBox.hgrow="ALWAYS">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </TextField>
                  <Button fx:id="searchButton" mnemonicParsing="false" prefHeight="42.0" prefWidth="120.0" style="-fx-background-color: #4A90E2; -fx-background-radius: 8; -fx-cursor: hand;" text="Tìm kiếm" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>

            <StackPane prefHeight="450.0">
               <children>
                  <ListView fx:id="topicListView" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 15px; -fx-padding: 5;" />
               </children>
            </StackPane>


         </children>
      </VBox>
      <Button fx:id="backButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="← Quay lại" textFill="#4a5568" StackPane.alignment="TOP_LEFT">
         <font><Font name="System Bold" size="14.0" /></font>
         <StackPane.margin>
            <Insets left="20.0" top="20.0" />
         </StackPane.margin>
      </Button>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</StackPane>