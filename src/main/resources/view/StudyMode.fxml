<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: transparent; -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.MainMenuController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 15 30;">
            <children>
                <Button onAction="#backToMainMenu" style="-fx-background-color: white; -fx-text-fill: #4a5568; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-cursor: hand;" text="← Trở về">
                    <font> <Font name="System Bold" size="14.0" /> </font>
                </Button>
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-font-weight: bold; -fx-font-size: 20;" text="Chế Độ Tập Trung" textFill="#1A365D" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="logoutButton" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0; -fx-cursor: hand;" text="Đăng xuất" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="30" style="-fx-padding: 20;">
            <children>

                <VBox alignment="CENTER" spacing="5" style="-fx-background-color: white; -fx-padding: 10 25; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                    <children>
                        <Label fx:id="timerDisplayLabel" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #E53E3E;" text="05:00" />
                        <Label style="-fx-text-fill: #A0AEC0;" text="⏱ Tự động lật thẻ sau 5 phút" />
                    </children>
                </VBox>

                <StackPane fx:id="flashcardPane" maxWidth="550.0" onMouseClicked="#handleFlipCard" prefHeight="350.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 20, 0, 0, 8);">
                    <children>
                        <VBox fx:id="frontCard" alignment="CENTER" spacing="15">
                            <children>
                                <Label style="-fx-text-fill: #A0AEC0;" text="MẶT TRƯỚC (CHẠM ĐỂ LẬT)" />
                                <Label fx:id="reviewVocabLabel" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Word" textAlignment="CENTER" wrapText="true" />
                            </children>
                        </VBox>

                        <VBox fx:id="backCard" alignment="CENTER" spacing="15" style="-fx-background-color: #F7FAFC; -fx-background-radius: 20; -fx-border-color: #4A90E2; -fx-border-width: 2; -fx-border-radius: 20;" visible="false">
                            <children>
                                <Label style="-fx-text-fill: #A0AEC0;" text="Ý NGHĨA" />
                                <Label fx:id="reviewDefLabel" style="-fx-font-size: 40; -fx-font-weight: bold; -fx-text-fill: #2B6CB0;" text="Definition" textAlignment="CENTER" wrapText="true" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <HBox alignment="CENTER" spacing="20">
                    <children>
                        <Button onAction="#handleRestartStudy" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #ED8936; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="🔄 Học lại">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>
                        <Button onAction="#handleMarkLearnedInStudy" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #48BB78; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="✔ Đã thuộc">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>
                        <Button onAction="#handleNextCard" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Tiếp theo ➔">
                            <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>