<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="720.0" prefWidth="900.0" style="-fx-background-color: transparent; -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.TestModeMenuController">
    <children>
        <VBox alignment="CENTER" maxWidth="600.0" spacing="30.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 5);" StackPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>

                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="LỰA CHỌN KIỂM TRA" textFill="#1A365D">
                        <font> <Font name="System Bold" size="24.0" /> </font>
                    </Label>
                    <Label text="Đánh giá năng lực của bạn thông qua các bài test" textFill="#718096">
                        <font> <Font size="14.0" /> </font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" spacing="20.0">
                    <children>
                        <VBox fx:id="topicTestBox" onMouseClicked="#handleTopicTest" style="-fx-cursor: hand;">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="450.0" spacing="20.0" style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 3);">
                                    <children>
                                        <StackPane prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #EBF8FF; -fx-background-radius: 25;">
                                            <Label text="📚" textFill="#3182CE">
                                                <font><Font size="24.0" /></font>
                                            </Label>
                                        </StackPane>
                                        <VBox alignment="CENTER_LEFT" spacing="2">
                                            <Label text="Kiểm Tra Theo Chủ Đề" textFill="#2D3748">
                                                <font> <Font name="System Bold" size="18.0" /> </font>
                                            </Label>
                                            <Label text="Lựa chọn một bộ từ vựng cụ thể" textFill="#A0AEC0">
                                                <font> <Font size="13.0" /> </font>
                                            </Label>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="randomTestBox" onMouseClicked="#handleRandomTest" style="-fx-cursor: hand;">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="450.0" spacing="20.0" style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 0 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 3);">
                                    <children>
                                        <StackPane prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #F0FFF4; -fx-background-radius: 25;">
                                            <Label text="🎲" textFill="#38A169">
                                                <font><Font size="24.0" /></font>
                                            </Label>
                                        </StackPane>
                                        <VBox alignment="CENTER_LEFT" spacing="2">
                                            <Label text="Kiểm Tra Ngẫu Nhiên" textFill="#2D3748">
                                                <font> <Font name="System Bold" size="18.0" /> </font>
                                            </Label>
                                            <Label text="Thử thách với các từ vựng ngẫu nhiên" textFill="#A0AEC0">
                                                <font> <Font size="13.0" /> </font>
                                            </Label>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: transparent; -fx-text-fill: #4A5568; -fx-cursor: hand;" text="← Quay lại">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </children>
</StackPane>