<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane prefHeight="768.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #f0f4ff, #d9e2ff); -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.VocabularyOfTopicController">
   <children>
      <VBox maxWidth="1100.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 4);" StackPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Text fx:id="textLabel" fill="#1A365D" strokeType="OUTSIDE" strokeWidth="0.0" text="Tên chủ đề">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Text>

            <VBox spacing="10.0" style="-fx-background-color: #F7FAFC; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">
               <children>
                  <HBox spacing="15.0">
                     <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                           <Label text="Từ vựng (English)" textFill="#4A5568">
                              <font> <Font name="System Bold" size="13.0" /> </font>
                           </Label>
                           <TextField fx:id="newVocabField" prefHeight="40.0" promptText="Nhập từ mới..." style="-fx-background-color: white; -fx-border-color: #cbd5e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="5">
                           <Label text="Nghĩa (Tiếng Việt)" textFill="#4A5568">
                              <font> <Font name="System Bold" size="13.0" /> </font>
                           </Label>
                           <TextField fx:id="newDefinitionField" prefHeight="40.0" promptText="Nhập nghĩa..." style="-fx-background-color: white; -fx-border-color: #cbd5e0; -fx-border-radius: 6; -fx-background-radius: 6;" />
                        </VBox>
                        <VBox alignment="BOTTOM_RIGHT">
                           <Button fx:id="addVocabButton" mnemonicParsing="false" onAction="#handleAddVocab" prefHeight="40.0" style="-fx-background-color: #48BB78; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;" text="+ Thêm từ">
                              <font> <Font name="System Bold" size="14.0" /> </font>
                           </Button>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>

            <TextField fx:id="searchVocabField" prefHeight="40.0" promptText="🔍 Tìm kiếm từ vựng trong chủ đề..." style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;">
               <font> <Font size="14.0" /> </font>
            </TextField>

            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
               <children>
                  <TableView fx:id="vocabTable" style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="vocabCol" prefWidth="250.0" style="-fx-font-size: 14px; -fx-alignment: CENTER-LEFT;" text="Từ vựng" />
                        <TableColumn fx:id="defCol" prefWidth="350.0" style="-fx-font-size: 14px; -fx-alignment: CENTER-LEFT;" text="Nghĩa" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>

                  <VBox spacing="15.0" alignment="TOP_CENTER" minWidth="120.0">
                     <children>
                        <Button fx:id="updateVocabButton" mnemonicParsing="false" onAction="#handleUpdateVocab" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Sửa từ">
                           <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>
                        <Button fx:id="deleteVocabButton" mnemonicParsing="false" onAction="#handleDeleteVocab" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #ED8936; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Xóa từ">
                           <font> <Font name="System Bold" size="14.0" /> </font>
                        </Button>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="deleteTopicButton" mnemonicParsing="false" onAction="#handleDeleteTopic" prefHeight="40.0" style="-fx-background-color: #E53E3E; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;" text="Xóa Chủ đề này">
                     <font> <Font name="System Bold" size="14.0" /> </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
      <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="← Quay lại" textFill="#4a5568" StackPane.alignment="TOP_LEFT">
         <font><Font name="System Bold" size="14.0" /></font>
         <StackPane.margin>
            <Insets left="20.0" top="20.0" />
         </StackPane.margin>
      </Button>
   </children>
</StackPane>