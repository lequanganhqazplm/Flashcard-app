<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane style="-fx-background-color: #F4F7F6; -fx-font-family: 'Segoe UI', Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.flashcardapp.controller.LoginController">
    <padding>
        <Insets bottom="30.0" left="60.0" right="60.0" top="30.0" />
    </padding>
    <children>
        <VBox alignment="CENTER" maxWidth="480.0" minWidth="400.0" prefWidth="440.0" spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 20, 0, 0, 5);">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <StackPane>
                    <children>
                        <Text fill="#1A365D" strokeType="OUTSIDE" strokeWidth="0.0" text="Chào mừng trở lại! 👋">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Text>
                    </children>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </StackPane>

                <VBox spacing="18.0">
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Tên đăng nhập" textFill="#4a5568">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="usernameField" prefHeight="45.0" promptText="Nhập tên đăng nhập của bạn" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </TextField>
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="Mật khẩu" textFill="#4a5568">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <StackPane>
                                    <children>
                                        <PasswordField fx:id="passwordField" onAction="#handleLogin" prefHeight="45.0" promptText="Nhập mật khẩu" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </PasswordField>
                                        <TextField fx:id="passwordVisibleField" managed="false" onAction="#handleLogin" prefHeight="45.0" promptText="Nhập mật khẩu" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 15;" visible="false">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </StackPane>

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <CheckBox fx:id="showPasswordCheckBox" mnemonicParsing="false" onAction="#togglePasswordVisibility" text="Hiện mật khẩu" textFill="#718096">
                                        <font>
                                            <Font size="13.0" />
                                        </font>
                                    </CheckBox>
                                    <StackPane HBox.hgrow="ALWAYS" />
                                    <Hyperlink fx:id="forgotPasswordLink" onAction="#handleForgotPassword" text="Quên mật khẩu?" textFill="#4A90E2">
                                        <font>
                                            <Font size="13.0" />
                                        </font>
                                    </Hyperlink>
                                </HBox>
                            </children>
                        </VBox>

                        <Label fx:id="loginErrorLabel" textFill="#e53e3e" visible="false" wrapText="true">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>

                        <Button defaultButton="true" maxWidth="Infinity" onAction="#handleLogin" prefHeight="45.0" style="-fx-background-color: #7B61FF; -fx-background-radius: 8; -fx-cursor: hand;" text="Đăng nhập" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Button>

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Chưa có tài khoản?" textFill="#718096">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                                <Hyperlink onAction="#goToRegister" text="Đăng ký ngay" textFill="#7B61FF">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Hyperlink>
                            </children>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>